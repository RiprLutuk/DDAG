# DDAG environment configuration (copy to .env and source, or export in your shell).
# Every value has a built-in default suited to local dev; override per environment.

# --- General ---
DDAG_ENV=dev                       # dev | staging | prod
DDAG_LOG_LEVEL=info                # debug | info | warn | error

# --- Metadata database (PostgreSQL 18, external) ---
DDAG_DB_HOST=localhost
DDAG_DB_PORT=1921
DDAG_DB_USER=lutuk
DDAG_DB_PASSWORD=
DDAG_DB_NAME=ddag
DDAG_DB_SSLMODE=disable
# Metadata pool tuning
DDAG_DB_MIN_CONNS=2
DDAG_DB_MAX_CONNS=10
DDAG_DB_MAX_CONN_LIFETIME=1h
DDAG_DB_MAX_CONN_IDLE=30m
DDAG_DB_HEALTH_PERIOD=1m
DDAG_DB_CONNECT_TIMEOUT=5s

# --- Redis (cache + rate limiter) ---
DDAG_REDIS_ADDR=localhost:6379
DDAG_REDIS_PASSWORD=
DDAG_REDIS_DB=0

# --- Secrets (envelope encryption master key, base64 of 32 bytes) ---
# Generate a real one: openssl rand -base64 32
DDAG_MASTER_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# --- OAuth2 / tokens ---
DDAG_TOKEN_ISSUER=https://ddag.local
DDAG_ACCESS_TOKEN_TTL=1h
DDAG_REFRESH_TOKEN_TTL=720h
DDAG_JWKS_URL=http://localhost:8081/.well-known/jwks.json   # gateway -> auth-service
DDAG_JWKS_REFRESH=5m

# --- Dashboard session (admin-backend) ---
DDAG_SESSION_SECRET=dev-insecure-session-secret-change-me
DDAG_SESSION_TTL=8h
DDAG_SESSION_COOKIE=ddag_session
DDAG_SESSION_COOKIE_SECURE=false
DDAG_MAX_FAILED_LOGIN=5
DDAG_LOCKOUT_WINDOW=15m
DDAG_DASHBOARD_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Gateway ---
DDAG_POLICY_MODE=inprocess         # inprocess | remote
DDAG_CACHE_MODE=inprocess          # inprocess | remote
DDAG_ROUTE_REFRESH=15s
DDAG_DEFAULT_LIMIT=100
DDAG_MAX_LIMIT=1000
DDAG_CONNECTOR_POSTGRES_URL=http://localhost:8090
DDAG_CONNECTOR_MYSQL_URL=http://localhost:8091
DDAG_CONNECTOR_ORACLE_URL=http://localhost:8092
DDAG_CONNECTOR_SQLSERVER_URL=http://localhost:8093

# --- Seed ---
DDAG_SUPERADMIN_PASSWORD=Admin#12345
DDAG_DEMO_CLIENT_SECRET=demo-secret-brim-001
DDAG_AUTO_MIGRATE=true             # admin-backend auto-migrates + core-seeds on boot
